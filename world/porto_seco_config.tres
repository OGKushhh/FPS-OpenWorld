[resource]
script = ExtResource("1_cfg")

grid_width = 8
buildings_per_frame = 6
grid_height = 8
block_size = 200.0
street_width = 25.0

enable_multi_size_blocks = true
large_block_chance = 0.12
wide_block_chance = 0.15
tall_block_chance = 0.10
enable_edge_extensions = true
edge_extension_chance = 0.6
max_edge_extensions = 30
empty_block_chance = 0.04

district_mode = 1
residential_ratio = 0.35
commercial_ratio = 0.40
industrial_ratio = 0.20
park_ratio = 0.05
noise_scale = 0.08

residential_buildings = Array[PackedScene]([ExtResource("r01"), ExtResource("r02"), ExtResource("r03"), ExtResource("r04"), ExtResource("r05"), ExtResource("r06"), ExtResource("r07"), ExtResource("r08"), ExtResource("r09"), ExtResource("r10"), ExtResource("r11"), ExtResource("r12")])
commercial_buildings = Array[PackedScene]([ExtResource("c01"), ExtResource("c02"), ExtResource("c03"), ExtResource("c04"), ExtResource("c05"), ExtResource("c06"), ExtResource("c07"), ExtResource("c08"), ExtResource("c09"), ExtResource("c10"), ExtResource("c11"), ExtResource("c12"), ExtResource("c13")])
industrial_buildings = Array[PackedScene]([ExtResource("i01"), ExtResource("i02"), ExtResource("i03"), ExtResource("i04"), ExtResource("i05"), ExtResource("i06"), ExtResource("i07"), ExtResource("i08"), ExtResource("i09"), ExtResource("i10")])
park_elements = Array[PackedScene]([ExtResource("p01"), ExtResource("p02"), ExtResource("p03"), ExtResource("p04"), ExtResource("p05"), ExtResource("p06"), ExtResource("p07")])

rotation_mode = 3
scale_variation = 0.1
enable_grid_aligned = true
front_setback = 5.0
side_setback = 4.0
rear_setback = 5.0

enable_residential_subdivisions = true
subdivision_mode = 1
subdivision_layout = 0
subdivision_street_width = 8.0
residential_buildings_min = 2
residential_buildings_max = 4
residential_spacing = 18.0
residential_border_margin = 10.0

commercial_buildings_min = 4
commercial_buildings_max = 7
commercial_spacing = 40.0
commercial_border_margin = 20.0

industrial_buildings_min = 6
industrial_buildings_max = 10
industrial_spacing = 25.0
industrial_border_margin = 15.0

park_elements_count_min = 8
park_elements_count_max = 20

enable_multi_story = true
floor_height = 3.0
procedural_wall_material = ExtResource("11_mat")
procedural_window_material = ExtResource("12_mat")
procedural_roof_material = ExtResource("13_mat")
residential_min_floors = 1
residential_max_floors = 3
commercial_min_floors = 2
commercial_max_floors = 8
industrial_min_floors = 1
industrial_max_floors = 3

generate_roads = true
generate_intersections = true
road_material = ExtResource("2_mat")
intersection_material = ExtResource("5_mat")
intersection_height_offset = 0.01
generate_subdivision_roads = true
subdivision_road_material = ExtResource("4_mat")
enable_main_avenues = true
avenue_width = 35.0
avenue_interval = 3
avenue_material = ExtResource("3_mat")
enable_roundabouts = false
enable_diagonal_roads = false

generate_collision = true
generate_navigation = false

enable_terrain = false

generate_ground = true
ground_height_offset = -0.05
ground_material = ExtResource("6_mat")
residential_ground_material = ExtResource("7_mat")
commercial_ground_material = ExtResource("8_mat")
industrial_ground_material = ExtResource("9_mat")
park_ground_material = ExtResource("10_mat")
